.container.py-5
  .row.justify-content-center
    .col-lg-8
      .card.shadow-sm.border-0
        .card-body.p-4.p-md-5
          h1.h3.fw-bold.mb-2 = t("billing.show.title")
          p.text-muted.small.mb-4 = t("billing.show.lead")

          .bg-light.rounded-3.p-3.mb-4
            h2.h6.fw-semibold.mb-3 = t("billing.show.pro_includes_title")
            = render "shared/pro_benefits_list"

          - if @subscription&.pro_entitled?
            .alert.alert-success.border-0
              strong = t("billing.show.pro_active")
              - if @subscription.current_period_ends_at
                .small.mt-1 = t("billing.show.period_ends", date: l(@subscription.current_period_ends_at, format: :long))
              - if @subscription.auto_renew?
                .small.text-muted.mt-2 = t("billing.show.auto_renew_on")
              - else
                .small.text-muted.mt-2 = t("billing.show.auto_renew_off")

            - if @subscription.auto_renew?
              = button_to t("billing.show.cancel_auto_renew"), billing_cancel_auto_renew_path, method: :patch, class: "btn btn-outline-secondary w-100 mt-2"
          - else
            p.text-muted.small.mb-3 = t("billing.show.free_plan")

            - if Yookassa::Configuration.configured?
              = form_with url: billing_checkout_path, method: :post, class: "vstack gap-3" do
                fieldset.border-0.p-0 aria-labelledby="billing-consents-legend"
                  legend#billing-consents-legend.form-label.small.fw-semibold.text-secondary.mb-2 = t("legal.billing_fieldset")
                  = render "shared/consent_checkbox", id: "agree_pro_terms", required: true, label_html: t("legal.agree_pro_terms_html")
                  = render "shared/consent_checkbox", id: "agree_auto_renew", required: true, label_html: t("legal.agree_auto_renew_html", price: Billing::ProPlan::MONTHLY_AMOUNT_CENTS / 100)
                  = render "shared/consent_checkbox", id: "agree_payment_partner", required: true, label_html: t("legal.agree_payment_partner_html")
                = submit_tag t("billing.show.checkout", price: Billing::ProPlan::MONTHLY_AMOUNT_CENTS / 100), class: "btn btn-primary w-100"
            - else
              .alert.alert-warning.border-0.small.mb-0 = t("billing.not_configured")

          .mt-4.pt-4.border-top
            .d-grid.gap-2
              = link_to t("billing.show.account_settings"), edit_user_registration_path, class: "btn btn-outline-primary"
              = link_to t("pages.shared.back_home"), root_path, class: "btn btn-outline-secondary"
